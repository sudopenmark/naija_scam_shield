      "hotline": "0800-CALL-EFCC (0800-2255-3322)"
    },
    "CBN Consumer Protection": {
      "url": "https://www.cbn.gov.ng/supervisory/ConsumerProtection.asp",
      "email": "cpd@cbn.gov.ng"
    },
    "NITDA (Cybercrime)": {
      "url": "https://nitda.gov.ng",
      "email": "info@nitda.gov.ng"
    },
    "Nigeria Cybercrime Advisory Council": {
      "url": "https://www.ncac.gov.ng"
    }
  }
}
